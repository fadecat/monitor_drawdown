# Local-only runtime configuration.
# Copy to .env.local and fill in your own values.

JISILU_USERNAME=your_jisilu_username
JISILU_PASSWORD=your_jisilu_password
CONFIG_PATH=./config.yaml
CALENDAR_WEBHOOK_URL=https://example.invalid/calendar-webhook

# Optional email alert channel. Defaults to QQ SMTP: smtp.qq.com:465.
RECEIVER_EMAIL=receiver1@example.com,receiver2@example.com
SMTP_USER=your_qq_email@qq.com
SMTP_PASS=your_qq_smtp_auth_code

# CCTDA 煤炭运销日报邮件状态文件
CCTDA_STATE_PATH=./data_state/cctda_coal_daily.json
CCTDA_PREVIEW_HTML_PATH=./cctda_coal_daily_email_preview.html
